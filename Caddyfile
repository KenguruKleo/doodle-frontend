:80 {
    root * /usr/share/caddy
    encode gzip zstd
    
    # Вмикаємо обробку шаблонів для всіх HTML файлів
    templates
    
    # Логіка для SPA: якщо файлу немає, віддаємо index.html
    try_files {path} /index.html

    # Кешування для статичних ассетів (JS, CSS, картинки) - 1 рік
    @static {
        path /assets/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Вимикаємо кешування для HTML-сторінок (особливо index.html)
    @html {
        path /*.html /
    }
    header @html Cache-Control "no-store, no-cache, must-revalidate"
    
    # Роздаємо статичні файли
    file_server
}